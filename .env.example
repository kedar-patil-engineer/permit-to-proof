# Copy this file to .env and fill in values to use the real LLM backends.
# The default Mock backend needs neither of these, so the app runs with an
# empty .env (or no .env at all).

# Hosted extraction with OpenAI. Get a key at https://platform.openai.com.
OPENAI_API_KEY=

# Local, private extraction with Ollama (https://ollama.com). Leave the default
# unless your Ollama server runs elsewhere.
OLLAMA_HOST=http://localhost:11434
